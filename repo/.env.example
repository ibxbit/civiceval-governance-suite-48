POSTGRES_PASSWORD=change_me_database_password
JWT_SECRET=change_this_to_a_secure_minimum_32_character_value
PUBLIC_HOSTNAME=localhost

# These must point to host directories located on encrypted storage.
ENCRYPTED_POSTGRES_PATH=/secure/eaglepoint/postgres
ENCRYPTED_CMS_STORAGE_PATH=/secure/eaglepoint/cms-storage

# TLS certificate and key consumed by the gateway container.
TLS_CERT_PATH=./ops/tls/dev/server.crt
TLS_KEY_PATH=./ops/tls/dev/server.key

# Optional admin seeding (disabled by default).
ENABLE_SEED_ADMIN=false
# SEED_ADMIN_PASSWORD_HASH=scrypt$16384$8$1$...
